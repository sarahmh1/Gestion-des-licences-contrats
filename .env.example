# =============================================================================
# Docker Compose — copiez en ".env" (même dossier que docker-compose.yml)
# Sur la VM SOC : /home/srv-app/.env (voir scripts/DEPLOY-GITHUB-ACTIONS.md)
# =============================================================================

# Expéditeur des mails automatiques (celui affiché dans Gmail : gerinfo2025@gmail.com)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=gerinfo2025@gmail.com
# Mot de passe d'application Google (16 caractères, SANS espaces)
SPRING_MAIL_PASSWORD=remplacez_par_votre_mot_de_passe_application
SPRING_MAIL_SMTP_STARTTLS=true
SPRING_MAIL_SMTP_STARTTLS_REQUIRED=true
SPRING_MAIL_SMTP_SSL=false

# URL où les utilisateurs ouvrent l'app (lien dans l'e-mail de vérification)
# PC local :
# APP_FRONTEND_BASE_URL=http://localhost:4200
# VM :
APP_FRONTEND_BASE_URL=http://192.168.1.50:4200

APP_MAIL_LOG_LINK=true
